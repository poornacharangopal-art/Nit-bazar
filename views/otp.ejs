<!DOCTYPE html>
<html>
<head>
    <title>NIT Bazaar - OTP Login</title>
    <link rel="stylesheet" href="/otp.css">
</head>

<body>

<div class="bg"></div>

<div class="card">

    <h1>Welcome to NIT Bazaar</h1>
    <p>Enter your email to receive OTP</p>

    <form action="/sendotp" method="POST">

        <input
            type="email"
            name="email"
            placeholder="Enter your email"
            id="emailInput"
            required
        >

        <button type="submit">Send OTP</button>

    </form>

</div>

</body>
</html>